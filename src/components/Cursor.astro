<!-- Only rendered on non-touch devices via JS -->
<div class="cursor-dot" id="cursorDot" aria-hidden="true"></div>
<div class="cursor-ring" id="cursorRing" aria-hidden="true"></div>

<style>
  .cursor-dot,
  .cursor-ring {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 9998;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  /* Small terminal-block dot */
  .cursor-dot {
    width: 6px;
    height: 14px;
    background: var(--accent);
    border-radius: 1px;
    transform: translate(-50%, -50%);
    animation: cursor-blink 1.1s step-end infinite;
  }

  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  /* Lagging outer ring */
  .cursor-ring {
    width: 36px;
    height: 36px;
    border: 1px solid rgba(0, 229, 160, 0.5);
    border-radius: 4px;
    transform: translate(-50%, -50%) rotate(0deg);
    transition:
      width   0.2s var(--ease-out),
      height  0.2s var(--ease-out),
      border-color 0.2s var(--ease-out),
      background   0.2s var(--ease-out);
  }

  /* Hover state — set via JS class */
  .cursor-ring.hovering {
    width: 52px;
    height: 52px;
    border-color: var(--accent);
    background: rgba(0, 229, 160, 0.06);
  }

  /* Click state */
  .cursor-ring.clicking {
    width: 24px;
    height: 24px;
    background: rgba(0, 229, 160, 0.15);
    border-color: var(--accent);
  }

  /* Hide native cursor on desktop */
  @media (pointer: fine) {
    * { cursor: none !important; }
  }
</style>

<script>
  // Only on devices with a fine pointer (mouse)
  if (window.matchMedia('(pointer: fine)').matches) {
    const dot  = document.getElementById('cursorDot')!;
    const ring = document.getElementById('cursorRing')!;

    let mouseX = 0, mouseY = 0;
    let ringX  = 0, ringY  = 0;
    let visible = false;

    // Show on first move
    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;

      if (!visible) {
        dot.style.opacity  = '1';
        ring.style.opacity = '1';
        visible = true;
      }
    });

    // Hide when leaving window
    document.addEventListener('mouseleave', () => {
      dot.style.opacity  = '0';
      ring.style.opacity = '0';
      visible = false;
    });
    document.addEventListener('mouseenter', () => {
      if (visible) {
        dot.style.opacity  = '1';
        ring.style.opacity = '1';
      }
    });

    // Hover state on interactive elements
    const hoverTargets = 'a, button, [role="tab"], input, textarea, label, [data-cursor-hover]';
    document.querySelectorAll(hoverTargets).forEach(el => {
      el.addEventListener('mouseenter', () => ring.classList.add('hovering'));
      el.addEventListener('mouseleave', () => ring.classList.remove('hovering'));
    });

    // Click feedback
    document.addEventListener('mousedown', () => ring.classList.add('clicking'));
    document.addEventListener('mouseup',   () => ring.classList.remove('clicking'));

    // Animate ring with lerp lag
    let rafId: number;
    const LERP = 0.12;

    function animate() {
      ringX += (mouseX - ringX) * LERP;
      ringY += (mouseY - ringY) * LERP;

      dot.style.transform  = `translate(calc(${mouseX}px - 50%), calc(${mouseY}px - 50%))`;
      ring.style.transform = `translate(calc(${ringX}px - 50%), calc(${ringY}px - 50%)) rotate(${ringX * 0.05}deg)`;

      rafId = requestAnimationFrame(animate);
    }

    animate();
  }
</script>
