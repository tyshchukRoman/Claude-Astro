---
import { siteConfig } from '../data/site';
---

<section class="hero section" id="hero">
  <!-- Ambient glow -->
  <div class="glow glow-1" aria-hidden="true"></div>
  <div class="glow glow-2" aria-hidden="true"></div>

  <div class="container hero-inner">
    <div class="hero-text">
      <p class="tag hero-tag">Available for projects</p>

      <h1 class="hero-title">
        WordPress<br />
        <span class="accent">Expert.</span>
      </h1>

      <p class="hero-desc">{siteConfig.description}</p>

      <div class="hero-actions">
        <a href="#contact" class="btn btn-primary">Let's work together</a>
        <a href="#services" class="btn btn-ghost">See what I do</a>
      </div>

      <div class="hero-stats">
        <div class="stat">
          <span class="stat-value" data-countup="9" data-suffix="+">0+</span>
          <span class="stat-label">Technologies</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-value" data-countup="100" data-suffix="%">0%</span>
          <span class="stat-label">Custom code</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-value" data-countup-infinity>∞</span>
          <span class="stat-label">Problems solved</span>
        </div>
      </div>
    </div>

    <div class="hero-photo-wrap">
      <div class="hero-photo-frame glass-border">
        <img
          src={siteConfig.photo}
          alt="Roman — WordPress Expert"
          class="hero-photo"
          width="480"
          height="600"
          loading="eager"
        />
        <!-- layers that appear on hover -->
        <div class="photo-overlay"></div>
        <div class="photo-scanlines" aria-hidden="true"></div>
        <div class="photo-glitch photo-glitch--r" aria-hidden="true"></div>
        <div class="photo-glitch photo-glitch--g" aria-hidden="true"></div>
        <div class="photo-hud" aria-hidden="true">
          <span class="hud-line hud-line--tl"></span>
          <span class="hud-line hud-line--tr"></span>
          <span class="hud-line hud-line--bl"></span>
          <span class="hud-line hud-line--br"></span>
          <span class="hud-label hud-label--top">SUBJECT_IDENTIFIED</span>
          <span class="hud-label hud-label--bottom">STATUS: ONLINE</span>
        </div>
      </div>
      <div class="terminal-badge">
        <span class="tb-dot tb-dot--green"></span>
        <span class="tb-dot tb-dot--yellow"></span>
        <span class="tb-dot tb-dot--red"></span>
        <span class="tb-text"><span class="tb-prompt">$</span> wp --version</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: 80px;
  }

  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }

  .glow-1 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(0, 229, 160, 0.08) 0%, transparent 70%);
    top: -100px;
    right: -100px;
  }

  .glow-2 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(0, 229, 160, 0.05) 0%, transparent 70%);
    bottom: 0;
    left: -100px;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  .hero-tag {
    margin-bottom: var(--space-md);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .hero-tag::after {
    content: '';
    display: inline-block;
    width: 8px;
    height: 8px;
    background: var(--accent);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
    margin-left: 0.25rem;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.8); }
  }

  .hero-title {
    margin-bottom: var(--space-md);
  }

  .accent { color: var(--accent); }

  .hero-desc {
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 520px;
    margin-bottom: var(--space-lg);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-bottom: var(--space-lg);
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .stat { display: flex; flex-direction: column; gap: 2px; }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--accent);
    font-family: var(--font-mono);
    line-height: 1;
  }

  .stat-label {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .stat-divider {
    width: 1px;
    height: 32px;
    background: var(--border);
  }

  /* Photo */
  .hero-photo-wrap {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .hero-photo-frame {
    position: relative;
    width: 100%;
    max-width: 420px;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--bg-card);
    isolation: isolate;
  }

  .hero-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out), filter 0.4s var(--ease-out);
  }

  .hero-photo-frame:hover .hero-photo {
    transform: scale(1.04);
    filter: brightness(0.75) contrast(1.1);
  }

  /* Bottom gradient */
  .photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(8, 11, 15, 0.7) 0%, transparent 55%);
    pointer-events: none;
    transition: opacity 0.4s var(--ease-out);
  }

  /* CRT scan lines */
  .photo-scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.18) 2px,
      rgba(0, 0, 0, 0.18) 4px
    );
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s var(--ease-out);
    z-index: 1;
  }

  .hero-photo-frame:hover .photo-scanlines {
    opacity: 1;
  }

  /* RGB split glitch channels */
  .photo-glitch {
    position: absolute;
    inset: 0;
    background-image: inherit;
    background-size: cover;
    background-position: center;
    opacity: 0;
    pointer-events: none;
    z-index: 2;
    mix-blend-mode: screen;
  }

  .photo-glitch--r {
    background-color: rgba(255, 0, 60, 0.15);
    transform: translateX(0);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .photo-glitch--g {
    background-color: rgba(0, 229, 160, 0.12);
    transform: translateX(0);
    transition: opacity 0.3s ease 0.05s, transform 0.3s ease 0.05s;
  }

  .hero-photo-frame:hover .photo-glitch--r {
    opacity: 1;
    transform: translateX(-3px);
    animation: glitch-r 3s step-end infinite 0.5s;
  }

  .hero-photo-frame:hover .photo-glitch--g {
    opacity: 1;
    transform: translateX(3px);
    animation: glitch-g 3s step-end infinite 0.5s;
  }

  @keyframes glitch-r {
    0%, 90%, 100% { transform: translateX(-3px); clip-path: none; }
    92%  { transform: translateX(-6px) translateY(2px); clip-path: inset(30% 0 50% 0); }
    94%  { transform: translateX(0); clip-path: inset(60% 0 20% 0); }
    96%  { transform: translateX(-3px); clip-path: none; }
  }

  @keyframes glitch-g {
    0%, 90%, 100% { transform: translateX(3px); clip-path: none; }
    93%  { transform: translateX(6px) translateY(-2px); clip-path: inset(50% 0 30% 0); }
    95%  { transform: translateX(0); clip-path: inset(10% 0 70% 0); }
    97%  { transform: translateX(3px); clip-path: none; }
  }

  /* HUD corners + labels */
  .photo-hud {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s var(--ease-out) 0.1s;
    z-index: 3;
  }

  .hero-photo-frame:hover .photo-hud {
    opacity: 1;
  }

  .hud-line {
    position: absolute;
    width: 18px;
    height: 18px;
    border-color: var(--accent);
    border-style: solid;
    border-width: 0;
  }

  .hud-line--tl { top: 12px;    left: 12px;  border-top-width: 2px; border-left-width: 2px; }
  .hud-line--tr { top: 12px;    right: 12px; border-top-width: 2px; border-right-width: 2px; }
  .hud-line--bl { bottom: 12px; left: 12px;  border-bottom-width: 2px; border-left-width: 2px; }
  .hud-line--br { bottom: 12px; right: 12px; border-bottom-width: 2px; border-right-width: 2px; }

  .hud-label {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 1rem;
    letter-spacing: 0.15em;
    color: var(--accent);
    text-transform: uppercase;
    white-space: nowrap;
    text-shadow: 0 0 8px rgba(0, 229, 160, 0.6);
  }

  .hud-label--top    { top: 14px; }
  .hud-label--bottom { bottom: 14px; }

  .terminal-badge {
    position: absolute;
    bottom: -16px;
    left: -16px;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.5rem 0.875rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    backdrop-filter: blur(8px);
    font-family: var(--font-mono);
    font-size: 1rem;
  }

  .tb-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  .tb-dot--green  { background: #00e5a0; }
  .tb-dot--yellow { background: #ffd166; }
  .tb-dot--red    { background: #ef476f; }

  .tb-prompt { color: var(--accent); margin-right: 0.25rem; }
  .tb-text { color: var(--text-muted); }

  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }

    .hero-photo-wrap {
      order: -1;
    }

    .hero-photo-frame {
      max-width: 300px;
    }

    .hero { min-height: auto; padding-top: 100px; }
  }

  @media (max-width: 480px) {
    .hero-stats { flex-wrap: wrap; gap: var(--space-sm); }
    .stat-divider { display: none; }
  }
</style>

<script>
  const DURATION = 1800; // ms
  const EASE = (t: number) => 1 - Math.pow(1 - t, 3); // ease-out cubic

  function animateCountup(el: HTMLElement) {
    const target = parseInt(el.dataset.countup ?? '0', 10);
    const suffix = el.dataset.suffix ?? '';
    const start = performance.now();

    function tick(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / DURATION, 1);
      const value = Math.round(EASE(progress) * target);
      el.textContent = value + suffix;
      if (progress < 1) requestAnimationFrame(tick);
    }

    requestAnimationFrame(tick);
  }

  function animateInfinity(el: HTMLElement) {
    // Flash through some chars before settling on ∞
    const chars = ['0', '1', '?', '#', '∞'];
    let i = 0;
    const interval = setInterval(() => {
      el.textContent = chars[i];
      i++;
      if (i >= chars.length) clearInterval(interval);
    }, DURATION / (chars.length * 2));
  }

  const stats = document.querySelector('.hero-stats');
  if (stats) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          observer.disconnect();

          document.querySelectorAll<HTMLElement>('[data-countup]')
            .forEach(el => animateCountup(el));

          document.querySelectorAll<HTMLElement>('[data-countup-infinity]')
            .forEach(el => animateInfinity(el));
        });
      },
      { threshold: 0.5 }
    );
    observer.observe(stats);
  }
</script>
