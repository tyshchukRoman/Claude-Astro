---
---

<section class="section" id="contact">
  <div class="divider"></div>
  <div class="container contact-inner">
    <div class="contact-text">
      <p class="tag">Get in touch</p>
      <h2 class="contact-heading">
        Let's work<br /><span class="accent">together</span>
      </h2>
      <p class="contact-sub">
        If you need a reliable WordPress developer who can solve problems and deliver
        high-quality work, feel free to get in touch. I'll be happy to discuss your project.
      </p>
    </div>

    <div class="contact-form-wrap glass-border">
      <form
        class="contact-form"
        action="https://formspree.io/f/mgonzrrb"
        method="POST"
        id="contactForm"
        novalidate
      >
        <div class="form-group" id="group-name">
          <label for="name">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            placeholder="Your name"
            autocomplete="name"
          />
          <span class="field-error" id="error-name"></span>
        </div>

        <div class="form-group" id="group-email">
          <label for="email">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="your@email.com"
            autocomplete="email"
          />
          <span class="field-error" id="error-email"></span>
        </div>

        <div class="form-group" id="group-message">
          <label for="message">Message</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            placeholder="Tell me about your project..."
          ></textarea>
          <span class="field-error" id="error-message"></span>
        </div>

        <div class="form-submit-row">
          <button type="submit" class="btn btn-primary submit-btn" id="submitBtn">
            <span class="submit-text">Send message</span>
            <span class="submit-arrow">→</span>
          </button>
          <span class="submit-error" id="submitError"></span>
        </div>
      </form>

      <div class="form-success" id="formSuccess">
        <span class="success-icon">✓</span>
        <h3>Message sent!</h3>
        <p>Thanks for reaching out. I'll get back to you shortly.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: start;
    padding-top: var(--space-xl);
  }

  .contact-heading {
    margin-top: var(--space-xs);
    margin-bottom: var(--space-md);
    line-height: 1.15;
  }

  .accent { color: var(--accent); }

  .contact-sub {
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* Form */
  .contact-form-wrap {
    background: var(--bg-card);
    padding: var(--space-lg);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  label {
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }

  input, textarea {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.75rem var(--space-sm);
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--text);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    resize: none;
    width: 100%;
  }

  input::placeholder, textarea::placeholder {
    color: rgba(232, 240, 248, 0.25);
  }

  input:focus, textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-dim);
  }

  /* Validation states */
  .form-group.invalid input,
  .form-group.invalid textarea {
    border-color: #ef476f;
    box-shadow: 0 0 0 3px rgba(239, 71, 111, 0.1);
  }

  .form-group.valid input,
  .form-group.valid textarea {
    border-color: var(--accent);
  }

  .field-error {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: #ef476f;
    letter-spacing: 0.04em;
    min-height: 1em;
  }

  /* Submit row */
  .form-submit-row {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .submit-btn {
    align-self: flex-start;
  }

  .submit-btn:disabled {
    opacity: 0.6;
    pointer-events: none;
  }

  .submit-arrow {
    transition: transform var(--transition-fast);
  }

  .submit-btn:hover .submit-arrow {
    transform: translateX(4px);
  }

  .submit-error {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: #ef476f;
  }

  /* Success */
  .form-success {
    text-align: center;
    padding: var(--space-lg);
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    display: none;
  }

  .form-success.visible {
    display: flex;
  }

  .success-icon {
    font-size: 2rem;
    color: var(--accent);
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--accent-dim);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .form-success p {
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .contact-inner {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form     = document.getElementById('contactForm') as HTMLFormElement;
  const success  = document.getElementById('formSuccess')!;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const submitError = document.getElementById('submitError')!;

  // ── Validation rules ──
  type FieldId = 'name' | 'email' | 'message';

  const rules: Record<FieldId, (v: string) => string> = {
    name:    v => v.trim().length < 2   ? 'Name must be at least 2 characters.' : '',
    email:   v => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim()) ? '' : 'Enter a valid email address.',
    message: v => v.trim().length < 10  ? 'Message must be at least 10 characters.' : '',
  };

  function validateField(id: FieldId): boolean {
    const el    = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement;
    const group = document.getElementById(`group-${id}`)!;
    const error = document.getElementById(`error-${id}`)!;
    const msg   = rules[id](el.value);

    error.textContent = msg;
    group.classList.toggle('invalid', !!msg);
    group.classList.toggle('valid',   !msg);
    return !msg;
  }

  // Validate on blur
  (['name', 'email', 'message'] as FieldId[]).forEach(id => {
    const el = document.getElementById(id)!;
    el.addEventListener('blur', () => validateField(id));
    el.addEventListener('input', () => {
      // Clear error as user types after a failed attempt
      const group = document.getElementById(`group-${id}`)!;
      if (group.classList.contains('invalid')) validateField(id);
    });
  });

  // ── Submit ──
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const fields: FieldId[] = ['name', 'email', 'message'];
    const allValid = fields.map(validateField).every(Boolean);
    if (!allValid) return;

    submitBtn.disabled = true;
    submitBtn.querySelector('.submit-text')!.textContent = 'Sending...';
    submitError.textContent = '';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.hidden = true;
        success.classList.add('visible');
      } else {
        const json = await res.json().catch(() => ({}));
        submitError.textContent = json?.error ?? 'Something went wrong. Please try again.';
        submitBtn.disabled = false;
        submitBtn.querySelector('.submit-text')!.textContent = 'Send message';
      }
    } catch {
      submitError.textContent = 'Network error. Please check your connection.';
      submitBtn.disabled = false;
      submitBtn.querySelector('.submit-text')!.textContent = 'Send message';
    }
  });
</script>
