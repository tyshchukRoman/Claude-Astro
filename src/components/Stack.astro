---
import { technologies } from '../data/site';
---

<section class="section" id="stack">
  <div class="divider"></div>
  <div class="container" style="padding-top: var(--space-xl);">
    <p class="tag">Technologies</p>
    <h2 class="section-title">My Stack</h2>

    <div class="tabs-layout">
      <!-- Tab buttons -->
      <div class="tab-list" role="tablist" aria-label="Technologies">
        {technologies.map((tech, i) => (
          <button
            class="tab-btn"
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`panel-${i}`}
            id={`tab-${i}`}
            data-index={i}
          >
            <span class="tab-label">{tech.label}</span>
            <span class="tab-name">{tech.name}</span>
          </button>
        ))}
      </div>

      <!-- Tab panels -->
      <div class="tab-panels">
        {technologies.map((tech, i) => (
          <div
            class="tab-panel glass-border"
            role="tabpanel"
            id={`panel-${i}`}
            aria-labelledby={`tab-${i}`}
            hidden={i !== 0}
          >
            <div class="panel-header">
              <span class="panel-tag">{tech.label}</span>
              <h3 class="panel-title">{tech.name}</h3>
            </div>
            <p class="panel-desc">{tech.description}</p>
            <ul class="panel-points" role="list">
              {tech.points.map(point => (
                <li class="panel-point">
                  <span class="point-arrow" aria-hidden="true">→</span>
                  {point}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .section-title {
    margin-top: var(--space-xs);
    margin-bottom: var(--space-lg);
  }

  .tabs-layout {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: var(--space-md);
    align-items: start;
  }

  /* ── Tab list ── */
  .tab-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
    position: sticky;
    top: 90px;
  }

  .tab-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.7rem var(--space-sm);
    border: none;
    background: transparent;
    border-radius: var(--radius-sm);
    cursor: pointer;
    text-align: left;
    color: var(--text-muted);
    transition: all var(--transition-fast);
    border-left: 2px solid transparent;
  }

  .tab-btn:hover {
    background: var(--bg-elevated);
    color: var(--text);
  }

  .tab-btn[aria-selected="true"] {
    background: var(--accent-dim);
    color: var(--accent);
    border-left-color: var(--accent);
  }

  .tab-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--bg-elevated);
    color: var(--text-muted);
    padding: 2px 5px;
    border-radius: 3px;
    min-width: 46px;
    text-align: center;
    transition: all var(--transition-fast);
    flex-shrink: 0;
  }

  .tab-btn[aria-selected="true"] .tab-label {
    background: var(--accent);
    color: #080b0f;
  }

  .tab-name {
    font-size: 1rem;
    font-weight: 500;
  }

  /* ── Panels ── */
  .tab-panels {
    min-height: 300px;
  }

  .tab-panel {
    background: var(--bg-card);
    padding: var(--space-lg);
    animation: fadeIn 0.25s var(--ease-out);
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .panel-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .panel-tag {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--accent);
    color: #080b0f;
    padding: 3px 8px;
    border-radius: 4px;
  }

  .panel-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
  }

  .panel-desc {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-md);
    max-width: 560px;
  }

  .panel-points {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .panel-point {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    font-size: 1rem;
    color: var(--text-muted);
  }

  .point-arrow {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 1rem;
    flex-shrink: 0;
    transition: transform var(--transition-fast);
  }

  .panel-point:hover .point-arrow {
    transform: translateX(4px);
  }

  .panel-point:hover {
    color: var(--text);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .tabs-layout {
      grid-template-columns: 1fr;
    }

    .tab-list {
      flex-direction: row;
      flex-wrap: wrap;
      position: static;
    }

    .tab-btn {
      border-left: none;
      border-bottom: 2px solid transparent;
      padding: 0.5rem 0.75rem;
    }

    .tab-btn[aria-selected="true"] {
      border-left-color: transparent;
      border-bottom-color: var(--accent);
    }

    .tab-name { display: none; }
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('[role="tab"]');
  const panels = document.querySelectorAll<HTMLElement>('[role="tabpanel"]');

  function selectTab(index: number) {
    tabs.forEach((tab, i) => {
      const selected = i === index;
      tab.setAttribute('aria-selected', String(selected));
    });
    panels.forEach((panel, i) => {
      panel.hidden = i !== index;
    });
  }

  tabs.forEach((tab, i) => {
    tab.addEventListener('click', () => selectTab(i));

    // Keyboard navigation
    tab.addEventListener('keydown', (e) => {
      const total = tabs.length;
      if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
        e.preventDefault();
        selectTab((i + 1) % total);
        (tabs[(i + 1) % total] as HTMLElement).focus();
      } else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
        e.preventDefault();
        selectTab((i - 1 + total) % total);
        (tabs[(i - 1 + total) % total] as HTMLElement).focus();
      }
    });
  });
</script>
